__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
.DS_Store
*.swp

# Raw data files are gitignored by default — override per-project as appropriate.
# We keep the directory tracked (via its README) so the structure is visible
# in a fresh clone and analysis scripts have somewhere to point at.
reference/raw-data/*
!reference/raw-data/README.md
!reference/raw-data/.gitkeep

# Quarto build artefacts
_site/
*.html
!live-docs/*.html
*_files/

# Local scratch
*.local.md
